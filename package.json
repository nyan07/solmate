{
    "name": "arkie",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "prepare": "husky || true",
        "test": "vitest run --passWithNoTests",
        "test:e2e": "playwright test",
        "vercel:preview": "url=$(vercel deploy) && vercel alias \"$url\" staging.arkie.app && echo \"Preview: https://staging.arkie.app\"",
        "vercel:prod": "vercel deploy --prod"
    },
    "dependencies": {
        "@phoenix344/opening-hours": "^2.0.0",
        "@posthog/react": "^1.9.0",
        "@react-google-maps/api": "^2.20.7",
        "@tailwindcss/vite": "^4.1.14",
        "@tanstack/react-query": "^5.90.2",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "cesium": "^1.134.0",
        "framer-motion": "^12.23.22",
        "i18next": "^26.0.3",
        "i18next-browser-languagedetector": "^8.2.1",
        "posthog-js": "^1.366.0",
        "react": "^19.2.0",
        "react-day-picker": "^9.11.0",
        "react-dom": "^19.2.0",
        "react-i18next": "^17.0.2",
        "react-icons": "^5.5.0",
        "react-router-dom": "^7.9.3",
        "suncalc": "^1.9.0",
        "tailwindcss": "^4.1.14",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@eslint/js": "^9.36.0",
        "@playwright/test": "^1.59.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/geojson": "^7946.0.16",
        "@types/google.maps": "^3.58.1",
        "@types/leaflet": "^1.9.20",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@types/suncalc": "^1.9.2",
        "@vitejs/plugin-react": "^5.0.4",
        "@vitest/ui": "^4.1.2",
        "eslint": "^9.36.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.23",
        "globals": "^16.4.0",
        "husky": "^9.1.7",
        "jsdom": "^29.0.1",
        "lint-staged": "^16.4.0",
        "msw": "^2.12.14",
        "prettier": "^3.8.1",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.45.0",
        "vite": "^7.1.9",
        "vite-plugin-svgr": "^4.5.0",
        "vitest": "^4.1.2"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@tailwindcss/oxide",
            "esbuild",
            "protobufjs"
        ]
    },
    "lint-staged": {
        "**/*.{ts,tsx}": [
            "prettier --write",
            "eslint --fix"
        ],
        "**/*.{js,json,css,md}": [
            "prettier --write"
        ],
        "src/i18n/locales/*.ts": [
            "node scripts/export-tranlations.js",
            "git add translations.md"
        ]
    }
}
